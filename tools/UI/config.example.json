  "gnbs": [
    {
      "node": "GNB1",
      "config": "./tools/UI/configs/gnb1.yaml",
      "args": []
    },
    {
      "node": "GNB2",
      "config": "./tools/UI/configs/gnb2.yaml",
      "args": []
    }
  ]
