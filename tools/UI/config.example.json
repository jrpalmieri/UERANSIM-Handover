{
  "executables": {
    "nr_cli": "./build/nr-cli",
    "nr_ue": "./build/nr-ue",
    "nr_gnb": "./build/nr-gnb"
  },
  "amf": {
    "host": "172.22.0.10",
    "port": 38412,
    "protocol": "sctp",
    "active_probe": false,
    "connect_timeout_sec": 1.0,
    "log_file": "/home/joe/repos/GT/cs8903/docker_open5gs/log/amf.log"
  },
  "ui": {
