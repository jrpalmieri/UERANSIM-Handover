    "netns_name": "ue1",
    "netns_prefix_len": 16,
    "ensure_host_route_to_ue": true,
    "host_route_gateway": "172.22.0.8",
    "host_route_subnet": "172.22.0.0/24",
    "max_log_lines": 400
  },
  "core_db": {
    "warn_missing_subscribers": true,
    "dbctl_script": "./tools/open5gs-dbctl.py",
    "db_uri": "mongodb://localhost/open5gs",
    "check_timeout_sec": 10.0,
    "python": "python3"
  },
  "ue": {
    "node": "UE1",
    "count": 100,
    "config": "./tools/UI/configs/ue1.yaml",
